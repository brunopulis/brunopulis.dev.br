{
  "name": "studio",
  "description": "Site para divulgação dos trabalhos como consultoria de acessibilidade.",
  "version": "1.0.0",
  "author": "Bruno Pulis",
  "license": "MIT",
  "scripts": {
    "start": "run-p dev:css dev:eleventy",
    "dev:css": "npx @tailwindcss/cli -i src/assets/css/tailwind.css -o src/assets/css/index.css --watch",
    "dev:eleventy": "eleventy --serve",
    "build": "npm run build:css && eleventy",
    "build:css": "npx @tailwindcss/cli -i src/assets/css/tailwind.css -o src/assets/css/index.css --minify",
    "clean": "rimraf _site src/assets/css/index.css"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-fetch": "^5.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@11ty/eleventy-plugin-webc": "^0.11.2",
    "@11ty/is-land": "^5.0.1",
    "lite-youtube-embed": "^0.3.4",
    "lucide-static": "^1.16.0",
    "markdown-it-table-of-contents": "^1.2.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@toycode/markdown-it-class": "^1.2.4",
    "cross-env": "^10.1.0",
    "cssnano": "^8.0.1",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.1",
    "html-minifier-terser": "^7.2.0",
    "luxon": "^3.5.0",
    "markdown-it": "^14.1.1",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-link-attributes": "^4.0.1",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-prism": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "pa11y-ci": "^4.1.0",
    "prettier-plugin-jinja-template": "^2.1.0",
    "rimraf": "^6.1.3",
    "sanitize-html": "^2.17.2",
    "sharp": "^0.34.3",
    "sharp-ico": "^0.1.5",
    "slugify": "^1.6.9",
    "svgo": "^4.0.1"
  }
}
