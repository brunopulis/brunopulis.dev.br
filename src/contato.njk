---
layout: base.njk
permalink: '/contato.html'
title: 'Contato'
description: 'Estou disponível para projetos de consultoria, auditoria e desenvolvimento acessível.'
---

<section class="page-content">
  <div class="mx-auto px-8 max-w-7xl">
    <h1 class="font-bold text-blood-red-950">{{ title }}</h1>
    <p class="lead">
      {{ description }}
    </p>

    <form class="contact-form" name="contact" action="https://formspree.io/f/SEU_FORM_ID" method="post">
      <div class="form-group">
        <label for="name">Nome</label>
        <input type="text" id="name" name="name" required />
      </div>
      <div class="form-group">
        <label for="email">E-mail</label>
        <input type="email" id="email" name="email" required />
      </div>
      <div class="form-group">
        <label for="message">Mensagem</label>
        <textarea id="message" name="message" rows="5" required></textarea>
      </div>
      <button type="submit" class="bg-blood-red-950 p-4 font-bold text-white">Enviar mensagem</button>
    </form>

    <div class="contact-info">
      <h2 class="font-bold text-blood-red-950">Outras formas de contato</h2>

      <ul class="list-disc">
        <li><strong>Email:</strong> <a href="mailto:hello@brunopulis.com" class="underline underline-offset-4 hover:no-underline">hello@brunopulis.com</a></li>
        <li><strong>Telefone:</strong> <a href="tel:5531973438008" class="underline underline-offset-4 hover:no-underline">+55 (31) 97343-8008</a></li>
      </ul>
    </div>
  </div>
</section>
